Windows Registry Editor Version 5.00

; ==========================================================
; bye-tcp-internet — GMVELOCITY Low-Latency Gaming Profile
; Author: ceo714
; GitHub: https://github.com/ceo714/bye-tcp-internet
; Version: 1.2.0
; Target: Windows 10 (22H2+) / Windows 11
; ==========================================================
;
; Philosophy: Minimal • Measurable • Reversible
;
; Description:
;   Superset of universal.reg — includes all baseline TCP/IP
;   overrides plus gaming-specific latency optimizations.
;   Designed for competitive/real-time scenarios.
;
; Apply:
;   1. Run as Administrator
;   2. Reboot system after import
;
; Verify after reboot:
;   netsh int tcp show global
;   powershell "Get-NetTCPSetting -SettingName internet"
;
; Use at your own risk. See gmvelocity-rollback.reg to undo.
; ==========================================================


; ----------------------------------------------------------
; Multimedia Network Throttling
; Removes artificial packet processing cap during gameplay
; ----------------------------------------------------------

[HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Multimedia\SystemProfile]
"NetworkThrottlingIndex"=dword:ffffffff
"SystemResponsiveness"=dword:00000000


; ----------------------------------------------------------
; MMCSS — Prioritize Games
; Raises scheduling priority for game tasks in the kernel
; ----------------------------------------------------------

[HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Multimedia\SystemProfile\Tasks\Games]
"GPU Priority"=dword:00000008
"Priority"=dword:00000006
"Scheduling Category"="High"
"SFIO Priority"="High"


; ----------------------------------------------------------
; TCP/IP Core Parameters
; Full superset of universal.reg baseline
; ----------------------------------------------------------

[HKEY_LOCAL_MACHINE\SYSTEM\CurrentControlSet\Services\Tcpip\Parameters]

; Standard TTL = 64
"DefaultTTL"=dword:00000040

; Path MTU Discovery — avoid fragmentation
"EnablePMTUDiscovery"=dword:00000001

; Disable black hole detection — latency overhead not worth it
"EnablePMTUBHDetect"=dword:00000000

; SACK — selective loss recovery
"SackOpts"=dword:00000001

; RFC 1323 Window Scaling only (timestamps skipped for lower overhead)
"Tcp1323Opts"=dword:00000001

; Expand ephemeral port range
"MaxUserPort"=dword:0000fffe

; TIME_WAIT: 30s — aggressive port reuse for fast reconnects
"TcpTimedWaitDelay"=dword:0000001e

; ECN disabled — gaming routers and ISPs often mishandle ECN
"EnableECNCapability"=dword:00000000


; ----------------------------------------------------------
; DNS — Aggressive Low-Latency Resolver Behavior
; Zero negative caching to avoid reconnect stalls after
; failed DNS lookups (e.g., server browser queries)
; ----------------------------------------------------------

[HKEY_LOCAL_MACHINE\SYSTEM\CurrentControlSet\Services\Dnscache\Parameters]
"NegativeCacheTime"=dword:00000000
"NetFailureCacheTime"=dword:00000000
"MaxNegativeCacheTtl"=dword:00000000


; ----------------------------------------------------------
; QoS Policy — Remove Reserved Bandwidth Limit
; ----------------------------------------------------------

[HKEY_LOCAL_MACHINE\SOFTWARE\Policies\Microsoft\Windows\Psched]
"NonBestEffortLimit"=dword:00000000
