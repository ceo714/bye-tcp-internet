{
  "$schema": "https://bye-tcp.internet/schemas/v2/profiles.schema.json",
  "version": "2.0",
  "schemaVersion": "2026-03",
  "profiles": [
    {
      "id": "default",
      "name": "Windows Default",
      "description": "Стандартные настройки Windows по умолчанию",
      "version": "1.0",
      "receiveWindowAutoTuningLevel": "normal",
      "congestionProvider": "default",
      "ecnCapability": "default",
      "receiveWindowScaling": "enabled",
      "sack": "enabled",
      "timestamps": "enabled"
    },
    {
