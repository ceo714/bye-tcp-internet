      "tcpAckFrequency": 2,
      "tcpNoDelay": 0,
      "tcpDelAckTicks": 2,
      "receiveWindowAutoTuningLevel": "experimental",
      "congestionProvider": "cubic",
      "ecnCapability": "enabled",
      "receiveWindowScaling": "enabled",
      "sack": "enabled",
      "timestamps": "enabled"
