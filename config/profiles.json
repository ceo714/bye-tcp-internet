      "tcpAckFrequency": 1,
      "tcpNoDelay": 1,
      "tcpDelAckTicks": 1,
      "receiveWindowAutoTuningLevel": "normal",
      "congestionProvider": "ctcp",
      "ecnCapability": "enabled",
      "receiveWindowScaling": "enabled",
      "sack": "enabled",
      "timestamps": "enabled"
