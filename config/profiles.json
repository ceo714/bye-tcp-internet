      "version": "1.0",
      "tcpAckFrequency": 1,
      "tcpNoDelay": 1,
      "tcpDelAckTicks": 0,
      "receiveWindowAutoTuningLevel": "disabled",
      "congestionProvider": "ctcp",
      "ecnCapability": "disabled",
      "receiveWindowScaling": "enabled",
      "sack": "enabled",
      "timestamps": "disabled"
    },
    {
