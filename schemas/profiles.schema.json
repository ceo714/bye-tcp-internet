{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://bye-tcp.internet/schemas/v2/profiles.schema.json",
  "title": "Bye-TCP Profiles Configuration",
  "description": "Schema for TCP/IP optimization profiles",
  "type": "object",
  "required": ["version", "schemaVersion", "profiles"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "Version of the configuration file"
    },
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}$",
      "description": "Schema version (YYYY-MM format)"
    },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$",
            "minLength": 1,
            "maxLength": 64,
            "description": "Unique profile identifier"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "description": "Display name"
          },
          "description": {
            "type": "string",
            "maxLength": 512,
            "description": "Profile description"
          },
          "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+$",
            "description": "Profile version"
          },
          "tcpAckFrequency": {
            "type": "integer",
            "minimum": 1,
            "maximum": 8,
            "description": "TCP Acknowledgment Frequency"
          },
          "tcpNoDelay": {
            "type": "integer",
            "enum": [0, 1],
            "description": "Disable Nagle's Algorithm (1=disabled, 0=enabled)"
          },
          "tcpDelAckTicks": {
            "type": "integer",
            "minimum": 0,
            "maximum": 8,
            "description": "TCP Delayed Acknowledgment Ticks"
          },
          "receiveWindowAutoTuningLevel": {
            "type": "string",
            "enum": ["disabled", "highlyrestricted", "restricted", "normal", "experimental"],
            "description": "Receive Window Auto-Tuning Level"
          },
          "congestionProvider": {
            "type": "string",
            "enum": ["default", "ctcp", "cubic", "ledbat"],
            "description": "Congestion Control Provider"
          },
          "ecnCapability": {
            "type": "string",
            "enum": ["disabled", "enabled", "default"],
            "description": "Explicit Congestion Notification"
          },
          "receiveWindowScaling": {
            "type": "string",
            "enum": ["disabled", "enabled", "default"],
            "description": "Receive Window Scaling"
          },
          "sack": {
            "type": "string",
            "enum": ["disabled", "enabled", "default"],
            "description": "Selective Acknowledgments"
          },
          "timestamps": {
            "type": "string",
            "enum": ["disabled", "enabled", "default"],
            "description": "TCP Timestamps"
          },
          "maxMss": {
            "type": "integer",
            "minimum": 536,
            "maximum": 65535,
            "description": "Maximum Segment Size"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
