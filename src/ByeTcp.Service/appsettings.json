{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft": "Warning",
      "System": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "System": "Warning"
      }
    }
  },
  "Service": {
    "LogsPath": "%PROGRAMDATA%\\ByeTcp\\logs",
    "LogFileNamePattern": "byetcp-.log",
    "RetainedFileCountLimit": 7,
    "GracefulShutdownTimeoutSeconds": 30,
    "ConfigPath": "config",
    "StatePath": "state",
    "CachePath": "cache",
    "SchemasPath": "schemas",
    "ServiceName": "ByeTcp",
    "RetryAttempts": 3,
    "RetryDelaySeconds": 2
  }
}
