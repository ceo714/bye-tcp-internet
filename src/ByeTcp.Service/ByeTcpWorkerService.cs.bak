using Microsoft.Extensions.Hosting;
using Microsoft.Extensions.Logging;
using ByeTcp.Core.Interfaces;
using ByeTcp.Core.Models;
using ByeTcp.Core.Monitors;
using ByeTcp.Core.Engine;
using ByeTcp.Core.Appliers;
using ByeTcp.Core.Diagnostics;

namespace ByeTcp.Service;

/// <summary>
/// Основная Windows Service для оптимизации TCP/IP
/// </summary>
public class ByeTcpWorkerService : BackgroundService
{
    private readonly ILogger<ByeTcpWorkerService> _logger;
    private readonly IHostApplicationLifetime _lifetime;
    
    private readonly IProcessMonitor _processMonitor;
    private readonly INetworkMonitor _networkMonitor;
    private readonly IDiagnosticsEngine _diagnosticsEngine;
    private readonly IRuleEngine _ruleEngine;
    private readonly ISettingsApplier _settingsApplier;
    
    private readonly string _configPath;
    private readonly string _logsPath;
    private readonly string _backupsPath;

    public ByeTcpWorkerService(
        ILogger<ByeTcpWorkerService> logger,
        IHostApplicationLifetime lifetime,
        IProcessMonitor processMonitor,
        INetworkMonitor networkMonitor,
        IDiagnosticsEngine diagnosticsEngine,
        IRuleEngine ruleEngine,
        ISettingsApplier settingsApplier)
    {
        _logger = logger;
        _lifetime = lifetime;
        _processMonitor = processMonitor;
        _networkMonitor = networkMonitor;
        _diagnosticsEngine = diagnosticsEngine;
        _ruleEngine = ruleEngine;
        _settingsApplier = settingsApplier;
        
        // Определяем пути
        var basePath = AppContext.BaseDirectory;
        _configPath = Path.Combine(basePath, "config");
        _logsPath = Path.Combine(basePath, "logs");
        _backupsPath = Path.Combine(basePath, "backups");
        
        // Создаем директории
        Directory.CreateDirectory(_configPath);
        Directory.CreateDirectory(_logsPath);
        Directory.CreateDirectory(_backupsPath);
    }

    /// <summary>
    /// Основной цикл службы
    /// </summary>
    protected override async Task ExecuteAsync(CancellationToken stoppingToken)
    {
        _logger.LogInformation("╔═══════════════════════════════════════════════════════════╗");
        _logger.LogInformation("║        Bye-TCP Internet Service v0.1.0                    ║");
        _logger.LogInformation("║  Адаптивный оптимизатор TCP/IP для Windows                ║");
        _logger.LogInformation("╚═══════════════════════════════════════════════════════════╝");
        
        try
        {
            // 1. Загрузка конфигурации
            await LoadConfigurationAsync();
            
            // 2. Создание резервной копии текущих настроек
            await CreateInitialBackupAsync();
            
            // 3. Подписка на события
            SubscribeToEvents();
            
            // 4. Запуск компонентов
            _logger.LogInformation("🚀 Запуск компонентов службы...");
            
            var tasks = new List<Task>
            {
                _processMonitor.StartAsync(stoppingToken),
                _networkMonitor.StartAsync(stoppingToken),
                _diagnosticsEngine.StartAsync(stoppingToken)
            };
            
            await Task.WhenAll(tasks);
            
            _logger.LogInformation("✅ Все компоненты запущены");
            _logger.LogInformation("📍 Путь к конфигурации: {ConfigPath}", _configPath);
            _logger.LogInformation("📍 Путь к логам: {LogsPath}", _logsPath);
            _logger.LogInformation("📍 Путь к резервным копиям: {BackupsPath}", _backupsPath);
            
            // 5. Применение начального профиля
            await ApplyInitialProfileAsync();
            
            // 6. Основной цикл (ожидание событий)
            await RunMainLoopAsync(stoppingToken);
        }
        catch (OperationCanceledException)
        {
            _logger.LogInformation("Служба остановлена по запросу");
        }
        catch (Exception ex)
        {
            _logger.LogCritical(ex, "Критическая ошибка в службе");
            throw;
        }
        finally
        {
            await CleanupAsync();
        }
    }

    /// <summary>
    /// Загрузка конфигурации
    /// </summary>
    private async Task LoadConfigurationAsync()
    {
        _logger.LogInformation("📂 Загрузка конфигурации...");
        
        var rulesPath = Path.Combine(_configPath, "rules.json");
        var profilesPath = Path.Combine(_configPath, "profiles.json");
        
        await _ruleEngine.LoadRulesAsync(rulesPath);
        await _ruleEngine.LoadProfilesAsync(profilesPath);
        
        _logger.LogInformation("✅ Конфигурация загружена");
    }

    /// <summary>
    /// Создание начальной резервной копии настроек
    /// </summary>
    private async Task CreateInitialBackupAsync()
    {
        try
        {
            _logger.LogInformation("💾 Создание резервной копии текущих настроек...");
            
            var backupFile = await _settingsApplier.ExportCurrentSettingsAsync(_backupsPath);
            
            _logger.LogInformation("✅ Резервная копия создана: {BackupFile}", backupFile);
        }
        catch (Exception ex)
        {
            _logger.LogWarning(ex, "Не удалось создать резервную копию настроек");
        }
    }

    /// <summary>
    /// Подписка на события компонентов
    /// </summary>
    private void SubscribeToEvents()
    {
        _processMonitor.ProcessStarted += OnProcessStarted;
        _processMonitor.ProcessExited += OnProcessExited;
        _networkMonitor.MetricsUpdated += OnMetricsUpdated;
        _diagnosticsEngine.DiagnosticsCompleted += OnDiagnosticsCompleted;
        _ruleEngine.ProfileChanged += OnProfileChanged;
    }

    /// <summary>
    /// Обработчик запуска процесса
    /// </summary>
    private void OnProcessStarted(object? sender, ProcessInfo process)
    {
        _logger.LogInformation("▶️ Процесс запущен: {ProcessName} (PID: {Pid})", process.Name, process.Pid);
        
        // Запускаем оценку правил
        EvaluateRules();
    }

    /// <summary>
    /// Обработчик завершения процесса
    /// </summary>
    private void OnProcessExited(object? sender, ProcessInfo process)
    {
        _logger.LogInformation("⏹️ Процесс завершен: {ProcessName} (PID: {Pid})", process.Name, process.Pid);
        
        // Запускаем оценку правил с задержкой
        Task.Run(async () =>
        {
            await Task.Delay(2000); // Ждем 2 секунды перед оценкой
            EvaluateRules();
        });
    }

    /// <summary>
    /// Обработчик обновления сетевых метрик
    /// </summary>
    private void OnMetricsUpdated(object? sender, NetworkMetrics metrics)
    {
        _logger.LogDebug("📊 Метрики обновлены: RTT={Rtt}ms, Jitter={Jitter}ms, Loss={Loss}%", 
            metrics.RttMs, metrics.JitterMs, metrics.PacketLossPercent);
        
        // Периодическая оценка правил на основе сетевых условий
        // (можно добавить логику переключения при ухудшении сети)
    }

    /// <summary>
    /// Обработчик завершения диагностики
    /// </summary>
    private void OnDiagnosticsCompleted(object? sender, DiagnosticResult result)
    {
        _logger.LogDebug("🔍 Диагностика: Primary={Primary}ms, Gateway={Gateway}", 
            result.PingPrimary.TotalMilliseconds,
            result.GatewayReachable ? "OK" : "FAIL");
    }

    /// <summary>
    /// Обработчик переключения профиля
    /// </summary>
    private async void OnProfileChanged(object? sender, RuleEvaluationResult result)
    {
        _logger.LogInformation("🔄 Профиль изменен: {ProfileId} ({Reason})", 
            result.ProfileId, result.Reason);
        
        // Применяем действия из результата
        foreach (var action in result.Actions)
        {
            try
            {
                await _settingsApplier.ApplyActionAsync(action, CancellationToken.None);
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Ошибка применения действия: {Target} = {Value}", 
                    action.Target, action.Value);
            }
        }
    }

    /// <summary>
    /// Оценка правил и выбор профиля
    /// </summary>
    private void EvaluateRules()
    {
        try
        {
            var processes = _processMonitor.GetRunningProcesses();
            var metrics = _networkMonitor.GetCurrentMetrics();
            
            _ruleEngine.Evaluate(processes, metrics);
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Ошибка оценки правил");
        }
    }

    /// <summary>
    /// Применение начального профиля
    /// </summary>
    private async Task ApplyInitialProfileAsync()
    {
        _logger.LogInformation("🎯 Применение начального профиля...");
        
        var defaultProfile = _ruleEngine.GetCurrentProfile();
        if (defaultProfile != null)
        {
            await _settingsApplier.ApplyProfileAsync(defaultProfile, CancellationToken.None);
        }
    }

    /// <summary>
    /// Основной цикл службы
    /// </summary>
    private async Task RunMainLoopAsync(CancellationToken stoppingToken)
    {
        _logger.LogInformation("🔄 Вход в основной цикл службы");
        
        try
        {
            while (!stoppingToken.IsCancellationRequested)
            {
                // Периодическая оценка правил (каждые 30 секунд)
                EvaluateRules();
                
                // Логирование статуса
                LogStatus();
                
                // Ждем следующего цикла
                await Task.Delay(TimeSpan.FromSeconds(30), stoppingToken);
            }
        }
        catch (OperationCanceledException)
        {
            // Нормальное завершение
        }
    }

    /// <summary>
    /// Логирование текущего статуса
    /// </summary>
    private void LogStatus()
    {
        var profile = _ruleEngine.GetCurrentProfile();
        var processes = _processMonitor.GetRunningProcesses();
        var metrics = _networkMonitor.GetCurrentMetrics();
        
        _logger.LogDebug(
            "📍 Статус: Профиль={Profile}, Процессы={Processes}, RTT={Rtt}ms",
            profile?.Name ?? "Unknown",
            processes.Count(p => p.State == ProcessState.Running),
            metrics.RttMs
        );
    }

    /// <summary>
    /// Очистка при остановке
    /// </summary>
    private async Task CleanupAsync()
    {
        _logger.LogInformation("🧹 Очистка ресурсов...");
        
        await _processMonitor.StopAsync();
        await _networkMonitor.StopAsync();
        await _diagnosticsEngine.StopAsync();
        
        _processMonitor.Dispose();
        _networkMonitor.Dispose();
        _diagnosticsEngine.Dispose();
        
        _logger.LogInformation("✅ Служба остановлена");
    }

    /// <summary>
    /// Переопределение для обработки неожиданной остановки
    /// </summary>
    public override async Task StopAsync(CancellationToken cancellationToken)
    {
        _logger.LogInformation("⏹️ Получен запрос на остановку службы");
        await base.StopAsync(cancellationToken);
    }
}
