<Page
    x:Class="ByeTcp.UI.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:ByeTcp.UI.ViewModels"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    xmlns:controls="using:ByeTcp.UI.Controls"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="16">
        <StackPanel Spacing="16">
            <!-- Header -->
            <TextBlock Text="Dashboard" Style="{StaticResource TitleLargeTextBlock}" Margin="0,0,0,8" />

            <!-- Service Status Card -->
            <controls:CardControl>
                <StackPanel Spacing="8">
                    <TextBlock Text="Service Status" Style="{StaticResource SubtitleTextBlock}" />
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon 
                                Glyph="&#xE74E;" 
                                FontSize="20"
                                Foreground="{Binding IsServiceRunning, Converter={StaticResource BoolToColorConverter}, FallbackValue=Red}" />
                            <TextBlock>
                                <Run Text="Status: " />
                                <Run Text="{Binding IsServiceRunning, FallbackValue=False}" 
                                     FontWeight="Bold"
                                     Foreground="{Binding IsServiceRunning, Converter={StaticResource BoolToColorConverter}, FallbackValue=Red}" />
                            </TextBlock>
                        </StackPanel>
                        <TextBlock>
                            <Run Text="Profile: " />
                            <Run Text="{Binding CurrentProfileName, FallbackValue=N/A}" FontWeight="Bold" />
                        </TextBlock>
                        <TextBlock>
                            <Run Text="Uptime: " />
                            <Run Text="{Binding Uptime, FallbackValue=00:00:00}" />
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </controls:CardControl>

            <!-- Network Metrics Cards -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <!-- RTT Card -->
                <controls:CardControl Grid.Column="0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="RTT (ms)" Style="{StaticResource BodyStrongTextBlock}" />
                        <TextBlock 
                            Text="{Binding RttMs, StringFormat={}{0:F1}}" 
                            FontSize="32" 
                            FontWeight="Bold"
                            Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                        <ProgressBar Value="{Binding RttMs}" Maximum="200" Height="4" />
                    </StackPanel>
                </controls:CardControl>

                <!-- Jitter Card -->
                <controls:CardControl Grid.Column="1">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Jitter (ms)" Style="{StaticResource BodyStrongTextBlock}" />
                        <TextBlock 
                            Text="{Binding JitterMs, StringFormat={}{0:F2}}" 
                            FontSize="32" 
                            FontWeight="Bold"
                            Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                        <ProgressBar Value="{Binding JitterMs}" Maximum="50" Height="4" />
                    </StackPanel>
                </controls:CardControl>

                <!-- Packet Loss Card -->
                <controls:CardControl Grid.Column="2">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Packet Loss (%)" Style="{StaticResource BodyStrongTextBlock}" />
                        <TextBlock 
                            Text="{Binding PacketLossPercent, StringFormat={}{0:F2}}" 
                            FontSize="32" 
                            FontWeight="Bold"
                            Foreground="{Binding PacketLossPercent, Converter={StaticResource LossToColorConverter}, FallbackValue=Green}" />
                        <ProgressBar Value="{Binding PacketLossPercent}" Maximum="10" Height="4" />
                    </StackPanel>
                </controls:CardControl>
            </Grid>

            <!-- Charts -->
            <Grid ColumnSpacing="16" RowSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="250" />
                </Grid.RowDefinitions>

                <!-- RTT Chart -->
                <controls:CardControl Grid.Column="0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="RTT History" Style="{StaticResource SubtitleTextBlock}" />
                        <lvc:CartesianChart
                            Series="{Binding RttSeries}"
                            XAxes="{Binding XAxes}"
                            Height="200"
                            ZoomMode="X" />
                    </StackPanel>
                </controls:CardControl>

                <!-- Jitter Chart -->
                <controls:CardControl Grid.Column="1">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Jitter History" Style="{StaticResource SubtitleTextBlock}" />
                        <lvc:CartesianChart
                            Series="{Binding JitterSeries}"
                            XAxes="{Binding XAxes}"
                            Height="200"
                            ZoomMode="X" />
                    </StackPanel>
                </controls:CardControl>
            </Grid>

            <!-- Quick Actions -->
            <controls:CardControl>
                <StackPanel Spacing="8">
                    <TextBlock Text="Quick Actions" Style="{StaticResource SubtitleTextBlock}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Refresh" Command="{Binding RefreshCommand}" />
                        <Button Content="Run Ping Test" Click="GoToDiagnostics_Click" />
                        <Button Content="View Logs" Click="GoToLogs_Click" />
                    </StackPanel>
                </StackPanel>
            </CardControl>

            <!-- Error Display -->
            <InfoBar
                IsOpen="{Binding ErrorMessage, Converter={StaticResource NullToBoolConverter}}"
                Severity="Error"
                Message="{Binding ErrorMessage}"
                IsClosable="True" />
        </StackPanel>
    </ScrollViewer>
</Page>
