<Page
    x:Class="ByeTcp.UI.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="16">
        <StackPanel Spacing="24" MaxWidth="800">
            <TextBlock Text="Settings" Style="{StaticResource TitleLargeTextBlock}" />

            <!-- Backup & Restore -->
            <CardControl>
                <StackPanel Spacing="16">
                    <TextBlock Text="Backup &amp; Restore" Style="{StaticResource SubtitleTextBlock}" />
                    
                    <StackPanel Spacing="8">
                        <Button Content="Create Backup" Icon="Save" Command="{Binding CreateBackupCommand}" HorizontalAlignment="Left" />
                        <TextBlock Text="Create a backup of current TCP/IP settings" Style="{StaticResource CaptionTextBlockStyle}" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <Button Content="Rollback to Previous" Icon="Undo" Command="{Binding RollbackCommand}" HorizontalAlignment="Left" />
                        <TextBlock Text="Restore previous settings" Style="{StaticResource CaptionTextBlockStyle}" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <Button 
                            Content="Reset to Windows Defaults" 
                            Icon="Refresh" 
                            Command="{Binding ResetToDefaultsCommand}"
                            Background="{ThemeResource SystemFillColorAttentionBrush}"
                            Foreground="White"
                            HorizontalAlignment="Left" />
                        <TextBlock Text="Reset all TCP/IP settings to Windows defaults" Style="{StaticResource CaptionTextBlockStyle}" />
                    </StackPanel>
                </StackPanel>
            </CardControl>

            <!-- Appearance -->
            <CardControl>
                <StackPanel Spacing="16">
                    <TextBlock Text="Appearance" Style="{StaticResource SubtitleTextBlock}" />
                    
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="8">
                            <TextBlock Text="Theme" Style="{StaticResource BodyStrongTextBlock}" />
                            <ComboBox SelectedItem="{Binding SelectedTheme, Mode=TwoWay}" Width="200">
                                <x:String>Light</x:String>
                                <x:String>Dark</x:String>
                                <x:String>System</x:String>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="8">
                            <TextBlock Text="Language" Style="{StaticResource BodyStrongTextBlock}" />
                            <ComboBox SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}" Width="200">
                                <x:String>English</x:String>
                                <x:String>Русский</x:String>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </CardControl>

            <!-- About -->
            <CardControl>
                <StackPanel Spacing="8">
                    <TextBlock Text="About" Style="{StaticResource SubtitleTextBlock}" />
                    
                    <StackPanel Spacing="4">
                        <TextBlock>
                            <Run Text="Bye-TCP Internet v2.0" FontWeight="Bold" />
                        </TextBlock>
                        <TextBlock Text="Adaptive TCP/IP Optimizer for Windows" Style="{StaticResource CaptionTextBlockStyle}" />
                        <TextBlock Text="© 2026 ByeTcp Project" Style="{StaticResource CaptionTextBlockStyle}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,8,0,0">
                        <HyperlinkButton Content="Documentation" NavigateUri="https://github.com/bye-tcp-internet/docs" />
                        <HyperlinkButton Content="GitHub" NavigateUri="https://github.com/bye-tcp-internet" />
                        <HyperlinkButton Content="Report Issue" NavigateUri="https://github.com/bye-tcp-internet/issues" />
                    </StackPanel>
                </StackPanel>
            </CardControl>
        </StackPanel>
    </ScrollViewer>
</Page>
