<Page
    x:Class="ByeTcp.UI.Views.LogsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header with Actions -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="Service Logs" Style="{StaticResource TitleLargeTextBlock}" />

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <ToggleButton 
                    Content="Live Mode" 
                    IsChecked="{Binding IsLiveMode, Mode=TwoWay}"
                    Command="{Binding ToggleLiveModeCommand}" />
                <Button Content="Refresh" Icon="Refresh" Command="{Binding LoadLogsCommand}" />
                <Button Content="Export" Icon="Save" Command="{Binding ExportLogsCommand}" />
            </StackPanel>
        </Grid>

        <!-- Filters -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="16" Margin="0,8,0,16">
            <ComboBox 
                Header="Level"
                SelectedItem="{Binding SelectedLevel, Mode=TwoWay}"
                Width="150">
                <x:String>All</x:String>
                <x:String>Information</x:String>
                <x:String>Warning</x:String>
                <x:String>Error</x:String>
                <x:String>Debug</x:String>
            </ComboBox>
            <TextBlock 
                VerticalAlignment="Bottom"
                Margin="0,0,0,8">
                <Run Text="Total: " />
                <Run Text="{Binding LogEntries.Count}" FontWeight="Bold" />
            </TextBlock>
        </StackPanel>

        <!-- Logs List (Virtualized) -->
        <ListView 
            Grid.Row="2"
            ItemsSource="{Binding LogEntries}"
            SelectionMode="Single">
            
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="0,4" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnSpacing="16" Padding="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>

                        <!-- Timestamp -->
                        <TextBlock Grid.Column="0" 
                                   Text="{Binding Timestamp, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" 
                                   Style="{StaticResource CaptionTextBlockStyle}" />

                        <!-- Level Badge -->
                        <Border Grid.Column="1" 
                                Padding="8,2" 
                                CornerRadius="4"
                                HorizontalAlignment="Left">
                            <Border.Background>
                                <SolidColorBrush Color="{Binding Level, Converter={StaticResource LevelToColorConverter}}" />
                            </Border.Background>
                            <TextBlock Text="{Binding Level}" 
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="White" />
                        </Border>

                        <!-- Component -->
                        <TextBlock Grid.Column="2" 
                                   Text="{Binding Component}" 
                                   Style="{StaticResource CaptionTextBlockStyle}" />

                        <!-- Message -->
                        <TextBlock Grid.Column="3" 
                                   Text="{Binding Message}" 
                                   TextWrapping="Wrap" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
