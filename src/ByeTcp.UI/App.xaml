<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="ByeTcp.UI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ByeTcp.UI"
    xmlns:converters="using:ByeTcp.UI.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="Themes/Generic.xaml" />
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Custom Colors -->
            <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#0078D4" />
            <SolidColorBrush x:Key="SuccessFillColorDefaultBrush" Color="#107C10" />
            <SolidColorBrush x:Key="WarningFillColorDefaultBrush" Color="#FF8C00" />
            <SolidColorBrush x:Key="ErrorFillColorDefaultBrush" Color="#D13438" />
            
            <!-- Value Converters -->
            <converters:BoolToColorConverter x:Key="BoolToColorConverter" />
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <converters:BoolNegationToVisibilityConverter x:Key="BoolNegationToVisibilityConverter" />
            <converters:BoolNegationConverter x:Key="BoolNegationConverter" />
            <converters:NullToBoolConverter x:Key="NullToBoolConverter" />
            <converters:LossToColorConverter x:Key="LossToColorConverter" />
            <converters:LevelToColorConverter x:Key="LevelToColorConverter" />
            <converters:QualityToColorConverter x:Key="QualityToColorConverter" />
            <converters:FormatStringConverter x:Key="FormatStringConverter" />
            <converters:TimeSpanToStringConverter x:Key="TimeSpanToStringConverter" />
            <converters:DateTimeToStringConverter x:Key="DateTimeToStringConverter" />
            <converters:DoubleToStringConverter x:Key="DoubleToStringConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
