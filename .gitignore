# ╔═══════════════════════════════════════════════════════════╗
# ║           .gitignore для Bye-TCP Internet                 ║
# ║  Исключает временные файлы сборки и личные настройки      ║
# ╚═══════════════════════════════════════════════════════════╝

# ═══════════════════════════════════════════════════════════
# Сборка и компиляция
# ═══════════════════════════════════════════════════════════
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
[Aa][Nn][Yy] [Cc][Pp][Uu]/

# ═══════════════════════════════════════════════════════════
# Visual Studio / Rider / VSCode
# ═══════════════════════════════════════════════════════════
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.sln.ide/
*.sln.cache
*.slnx
*.slnx.cache
.idea/
*.swp
*.swo
*~
.vscode/settings.json
.vscode/launch.json

# ═══════════════════════════════════════════════════════════
# NuGet пакеты
# ═══════════════════════════════════════════════════════════
packages/
*.nupkg
*.snupkg
.nuget/

# ═══════════════════════════════════════════════════════════
# Публикация и артефакты
# ═══════════════════════════════════════════════════════════
publish/
artifacts/
*.dll
*.exe
*.pdb
*.ilk
*.exp
*.lib
*.appx
*.msix
*.appxsym
*.pri

# ═══════════════════════════════════════════════════════════
# Логи и временные файлы
# ═══════════════════════════════════════════════════════════
logs/
*.log
tmp/
temp/
*.tmp
*.cache
Thumbs.db
desktop.ini
.DS_Store

# ═══════════════════════════════════════════════════════════
# Тесты
# ═══════════════════════════════════════════════════════════
TestResults/
coverage/
*.coverage
*.coveragexml
*.trx

# ═══════════════════════════════════════════════════════════
# C++ / Native проекты
# ═══════════════════════════════════════════════════════════
ipch/
*.aps
*.ncb
*.opt
*.plg
*.idb
*.sdf
*.cachefile
*.VC.db
*.VC.VC.opendb
*.tlog
*.lastbuildstate

# ═══════════════════════════════════════════════════════════
# Личные данные и бэкапы
# ═══════════════════════════════════════════════════════════
backups/
*.reg
*.bat
*.ps1.bak
config/local.json
config/*.local.json
state/
cache/

# ═══════════════════════════════════════════════════════════
# Node.js (если используется)
# ═══════════════════════════════════════════════════════════
node_modules/
npm-debug.log
yarn-error.log

# ═══════════════════════════════════════════════════════════
# Python (если используется)
# ═══════════════════════════════════════════════════════════
__pycache__/
*.py[cod]
*$py.class
.Python
venv/
env/
.env

# ═══════════════════════════════════════════════════════════
# Git
# ═══════════════════════════════════════════════════════════
.gitattributes
.gitmodules

# ═══════════════════════════════════════════════════════════
# Документация (опционально)
# ═══════════════════════════════════════════════════════════
# docs/*.md~
# *.pdf

# ═══════════════════════════════════════════════════════════
# Исключения (что НЕ игнорировать)
# ═══════════════════════════════════════════════════════════
!config/profiles.json
!config/rules.json
!config/settings.json
!schemas/*.json
!scripts/*.ps1
!*.sln
!*.csproj
!*.vcxproj
!README*.md
!LICENSE
!cleanup.ps1
